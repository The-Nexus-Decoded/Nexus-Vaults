# Required Variables for .env (Production)
# --------------------------------------------------

# 1. Network & RPC
# Use a high-performance private RPC for production
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# 2. Wallet Configuration
# Path to the Hugh the Hand trading wallet JSON
TRADER_WALLET_PATH=/data/openclaw/wallets/trader.json
# Or private key string (less secure, but supported)
# TRADER_PRIVATE_KEY=...

# 3. Execution Parameters
DEFAULT_BUY_AMOUNT_SOL=0.1
DEFAULT_SLIPPAGE_BPS=100
MAX_JITO_TIP_SOL=0.001

# 4. Intelligence & Security API Keys
DEXSCREENER_API_KEY=not_required_for_free_tier
GMGN_API_KEY=your_key_here
RUGCHECK_API_KEY=your_key_here

# 5. External Indicators
PUMP_FUN_WS_URL=wss://pumpportal.fun/api/data

# 6. Database Configuration
LEDGER_DB_PATH=/data/repos/Pryan-Fire/data/ledger.db
